      },
      "delete": {
        "tags": ["Owner"],
        "summary": "Delete owner",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },

    "/owners/me/profile": {
      "get": {
        "tags": ["Owner"],
        "summary": "Get my owner profile",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": { "description": "Owner profile" }
        }
      }
    },

    "/owners/{ownerId}/listings": {
      "get": {
        "tags": ["Owner"],
        "summary": "Get owner listings",
        "parameters": [
          { "name": "ownerId", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Listings returned" }
        }
      }
    },

    "/attractions": {
      "get": {
        "tags": ["Attraction"],
        "summary": "Get all attractions",
        "responses": {
          "200": { "description": "List of attractions" }
        }
      },
      "post": {
        "tags": ["Attraction"],
        "summary": "Create attraction",
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "schema": { "$ref": "#/definitions/Attraction" }
          }
        ],
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },

    "/reviews": {
      "get": {
        "tags": ["Review"],
        "summary": "Get all reviews",
        "responses": {
          "200": { "description": "Reviews list" }
        }
      },
      "post": {
        "tags": ["Review"],
        "summary": "Create review",
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "schema": { "$ref": "#/definitions/Review" }
          }
        ],
        "responses": {
          "201": { "description": "Review created" }
        }
      }
    },

    "/favorites": {
      "get": {
        "tags": ["Favorite"],
        "summary": "Get user favorites",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": { "description": "Favorites list" }
        }
      },
      "post": {
        "tags": ["Favorite"],
        "summary": "Add to favorites",
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "schema": { "$ref": "#/definitions/Favorite" }
          }
        ],
        "responses": {
          "201": { "description": "Added" }
        }
      }
    },

    "/notifications": {
      "get": {
        "tags": ["Notification"],
        "summary": "Get my notifications",
        "security": [{ "Bearer": [] }],
