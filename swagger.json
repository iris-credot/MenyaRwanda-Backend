      },
      "put": {
        "tags": ["Owner"],
        "summary": "Update owner",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "body",
            "schema": { "$ref": "#/definitions/Owner" }
          }
        ],
        "responses": {
          "200": { "description": "Updated" }
