        }
      }
    },

    "/events": {
      "get": {
        "tags": ["Event"],
        "summary": "Get all events",
        "responses": {
          "200": { "description": "Events list" }
        }
      },
      "post": {
        "tags": ["Event"],
        "summary": "Create event",
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "in": "body",
