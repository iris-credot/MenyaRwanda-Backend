          "200": { "description": "Notifications list" }
        }
      }
    },

    "/chat": {
      "get": {
        "tags": ["Chat"],
        "summary": "Get my chat",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": { "description": "Chat data" }
        }
      }
    },

    "/chat/send": {
      "post": {
        "tags": ["Chat"],
        "summary": "Send message",
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "schema": { "$ref": "#/definitions/Message" }
          }
        ],
        "responses": {
