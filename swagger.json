"/attractions/create": {
  "post": {
    "tags": ["Attraction"],
    "summary": "Create attraction (Staff/Admin)",
    "security": [{ "Bearer": [] }],
    "consumes": ["multipart/form-data"],
    "parameters": [
      { "in": "formData", "name": "name", "type": "string", "required": true },
      { "in": "formData", "name": "description", "type": "string" },
      { "in": "formData", "name": "location", "type": "string", "required": true },
      { "in": "formData", "name": "district", "type": "string" },
      { "in": "formData", "name": "province", "type": "string" },
      { "in": "formData", "name": "type", "type": "string", "required": true },
      { "in": "formData", "name": "phone", "type": "string" },
      { "in": "formData", "name": "email", "type": "string" },
      { "in": "formData", "name": "openingHours", "type": "string" },

      {
        "in": "formData",
        "name": "images",
        "type": "file",
        "collectionFormat": "multi"
      }
    ],
    "responses": {
      "201": { "description": "Attraction created" }
    }
  }
},
"/attractions/update/{id}": {
  "put": {
    "tags": ["Attraction"],
    "summary": "Update attraction (Owner/Admin)",
